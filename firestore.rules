rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper to check if user is a participant in a private chat
    function isParticipant(participants) {
      return isAuth() && (request.auth.uid in participants);
    }

    // Private Chats: Access restricted to participants only
    match /privateChats/{chatId} {
      // Separated list and get for clearer debugging and query compliance
      allow get: if isParticipant(resource.data.participants);
      allow list: if isParticipant(resource.data.participants);
      
      // Allow creation if the creating user is one of the participants
      allow create: if isParticipant(request.resource.data.participants);

      // Allow updates (like lastMessage) if user is a participant
      allow update: if isParticipant(resource.data.participants);

      match /messages/{messageId} {
        // Participants of the parent chat can read and write messages
        allow read, write: if isAuth() && (
          request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants
        );
      }
    }
    
    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }
    
    // Groups and Unions: Standard authenticated access
    match /groups/{groupId} {
      allow read, write: if isAuth();
    }
    match /unions/{unionId} {
      allow read, write: if isAuth();
    }

    // Follows: Public read, Authenticated write
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Fallback for other paths
    match /{path=**} {
      allow read, write: if isAuth();
    }
  }
}