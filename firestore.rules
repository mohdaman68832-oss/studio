
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Private Chats: Rule optimized for 'array-contains' index queries
    match /privateChats/{chatId} {
      // Simplified read rule to ensure index verification passes seamlessly
      allow read: if isAuth() && (request.auth.uid in resource.data.participants);
      
      allow create: if isAuth() && (request.auth.uid in request.resource.data.participants);
      
      allow update: if isAuth() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        allow read, write: if isAuth();
      }
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // Follows: Authenticated write
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuth() && (request.auth.uid == request.resource.data.followerId || (resource != null && request.auth.uid == resource.data.followerId));
    }
    
    // Global Fallback (Secure by default)
    match /{path=**} {
      allow read, write: if isAuth();
    }
  }
}
