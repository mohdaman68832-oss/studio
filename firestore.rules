rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Post Collection: Anyone can read, only authenticated users can create
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;

      // Allow listing subcollections like "likes"
      match /likes/{likeId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    
    // UserProfiles: Public read for personalization, owner can write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default catch-all for other collections used in testing
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}