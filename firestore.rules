rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * InnovateSphere Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements an Authorization Independence model via denormalization. 
     * Security decisions are primarily made using data stored directly on the document 
     * being accessed (e.g., ownerId, participantIds) to ensure high performance and 
     * reduce cross-document lookups (get() calls).
     * 
     * Data Structure:
     * - /userProfiles/{userId}: Publicly viewable profiles, owner-only writes.
     * - /ideas/{ideaId}: Public innovation feed, author-only management.
     * - /ideaRatings & /ideaFeedbacks: Public community contributions, creator-only management.
     * - /collaborationSessions: Private group-based access for collaborators.
     * - /collaborationSessions/.../chatMessages: Member-only real-time messaging.
     * 
     * Key Security Decisions:
     * 1. Public Discovery: Ideas, Ratings, and Feedbacks are globally readable to foster 
     *    an open innovation community, while writes are strictly restricted to authors.
     * 2. Collaborative Security: Sessions use a 'participantIds' array (membership map) 
     *    stored on the document to grant access to a specific group of users.
     * 3. Relational Integrity: On creation, documents must include the authenticated 
     *    user's UID in the respective ownership field (authorId, raterId, etc.).
     * 4. Immutability: Ownership fields are immutable; once a document is created, 
     *    its link to the creator cannot be changed.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks ownership for existing documents during update or delete. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user is present in a list of participant UIDs. */
    function isMember(participantIds) {
      return isSignedIn() && (request.auth.uid in participantIds);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for User Profiles. Publicly readable; owner-only creation and updates.
     * @path /userProfiles/{userId}
     * @allow get, list: if true; (Public viewing)
     * @allow create: if isOwner(userId) && request.resource.data.id == userId;
     * @deny update: if request.auth.uid != userId; (Cannot edit someone else's profile)
     * @principle Path-based ownership and self-creation.
     */
    match /userProfiles/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for Ideas. Public feed; author-only management.
     * @path /ideas/{ideaId}
     * @allow get, list: if true; (Public feed)
     * @allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
     * @deny update: if resource.data.authorId != request.auth.uid;
     * @principle Public read with owner-only writes using denormalized 'authorId'.
     */
    match /ideas/{ideaId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.authorId) && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isExistingOwner(resource.data.authorId);
    }

    /**
     * @description Rules for Idea Ratings. Publicly readable to allow aggregate scores.
     * @path /ideaRatings/{ratingId}
     * @allow create: if isSignedIn() && request.resource.data.raterId == request.auth.uid;
     * @deny delete: if request.auth.uid != resource.data.raterId;
     * @principle Validates relational integrity by enforcing 'raterId' matches auth UID.
     */
    match /ideaRatings/{ratingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.raterId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.raterId) && request.resource.data.raterId == resource.data.raterId;
      allow delete: if isExistingOwner(resource.data.raterId);
    }

    /**
     * @description Rules for Idea Feedback. Public comments; author-only management.
     * @path /ideaFeedbacks/{feedbackId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn() && request.resource.data.feedbackerId == request.auth.uid;
     * @deny update: if request.resource.data.feedbackerId != resource.data.feedbackerId;
     * @principle Enforces immutability of the 'feedbackerId' field.
     */
    match /ideaFeedbacks/{feedbackId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.feedbackerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.feedbackerId) && request.resource.data.feedbackerId == resource.data.feedbackerId;
      allow delete: if isExistingOwner(resource.data.feedbackerId);
    }

    /**
     * @description Rules for Collaboration Sessions. Private to creator and invited members.
     * @path /collaborationSessions/{sessionId}
     * @allow get: if isMember(resource.data.participantIds) || isOwner(resource.data.creatorId);
     * @allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
     * @deny list: if !isSignedIn();
     * @principle Shared access pattern using 'participantIds' as a membership map.
     */
    match /collaborationSessions/{sessionId} {
      allow get: if isMember(resource.data.participantIds) || isOwner(resource.data.creatorId);
      allow list: if isSignedIn(); // Filtering is expected via 'array-contains' on participantIds
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.creatorId) || isMember(resource.data.participantIds);
      allow delete: if isExistingOwner(resource.data.creatorId);

      /**
       * @description Rules for Chat Messages. Nested inside sessions; requires session membership.
       * @path /collaborationSessions/{sessionId}/chatMessages/{messageId}
       * @allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
       * @principle Uses denormalized session context for authorization independence.
       */
      match /chatMessages/{messageId} {
        // IR reasoning states participantIds should be denormalized here to avoid get()
        allow get: if isOwner(resource.data.senderId) || isMember(resource.data.participantIds);
        allow list: if isSignedIn(); // Filtering should be applied by client
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update: if isExistingOwner(resource.data.senderId) && request.resource.data.senderId == resource.data.senderId;
        allow delete: if isExistingOwner(resource.data.senderId);
      }
    }
  }
}