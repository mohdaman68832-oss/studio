rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is a participant of a chat
    function isChatParticipant(participants) {
      return request.auth != null && (request.auth.uid in participants);
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Private Chats: Access restricted to participants only
    match /privateChats/{chatId} {
      // Allow list only if the query filters by participants array containing the auth.uid
      allow list: if request.auth != null && (
        request.auth.uid in resource.data.participants
      );
      
      // Allow get for specific chat if user is a participant
      allow get: if request.auth != null && (
        request.auth.uid in resource.data.participants
      );
      
      // Allow creation if the creating user is one of the participants
      allow create: if request.auth != null && (
        request.auth.uid in request.resource.data.participants
      );

      // Allow updates (like lastMessage) if user is a participant
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.participants
      );

      match /messages/{messageId} {
        // Participants of the parent chat can read and write messages
        // Using get() here to verify parent chat participants
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants
        );
      }
    }
    
    // Posts and subcollections: Authenticated read/write
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /likes/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    
    // Groups and other collections
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Legacy users collection fallback
    match /users/{userId}/{allPaths=**} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}