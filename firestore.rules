
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profiles Rules
    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Ideas and Posts Rules
    match /ideas/{ideaId} {
      // Allow everyone to view posts and list the feed
      allow get, list: if true;
      allow create: if isSignedIn();
      
      // Allow update if user is creator OR if they are only updating the 'likes' count
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || 
        resource.data.creatorId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
      );
      
      allow delete: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || 
        resource.data.creatorId == request.auth.uid
      );

      // Suggestions (Comments) within a post
      match /suggestions/{suggestionId} {
        allow get, list: if true;
        allow create: if isSignedIn();
      }
      
      // Likes tracking
      match /likes/{userId} {
        allow get, list: if true;
        allow write: if isOwner(userId);
      }
      
      // Collaboration Chat Sessions
      match /chatSessions/{chatId} {
        allow read, write: if isSignedIn();
        match /messages/{msgId} {
          allow read, write: if isSignedIn();
        }
      }
    }

    // Notifications Rules
    match /users/{userId}/notifications/{notificationId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isSignedIn();
    }

    // Private Messages
    match /messages/{messageId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
    
    // Community Groups
    match /groups/{groupId} {
      allow read, write: if isSignedIn();
    }
    
    // Professional Unions
    match /unions/{unionId} {
      allow read, write: if isSignedIn();
    }

    // Follow System
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    // Collaboration Requests
    match /collaborationRequests/{requestId} {
      allow read, write: if isSignedIn();
    }
  }
}
