rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is a participant of a chat
    function isChatParticipant(chatId) {
      return request.auth != null && (
        request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants
      );
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Private Chats: Access restricted to participants only
    match /privateChats/{chatId} {
      // Allow read/list if user is in participants array. 
      // This is the CRITICAL fix for 'array-contains' queries on the Hub page.
      allow read, list: if request.auth != null && (
        request.auth.uid in resource.data.participants
      );
      
      // Allow creation/updates if user is one of the participants
      allow write, create: if request.auth != null && (
        request.auth.uid in request.resource.data.participants
      );

      match /messages/{messageId} {
        // Participants of the parent chat can read and write messages
        allow read, write: if isChatParticipant(chatId);
      }
    }
    
    // Posts and subcollections: Authenticated read/write
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /likes/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    
    // Groups and other collections
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/{allPaths=**} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Global fallback for authenticated users
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}