
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * InnovateSphere Security Rules
     * Optimized for public read access and authenticated writes.
     */

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profiles: Anyone can view, only owner can edit.
    match /userProfiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Ideas: Publicly readable, authenticated users can create/update.
    match /ideas/{ideaId} {
      allow read: if true;
      allow create: if isSignedIn();
      // Allow any signed in user to update (needed for likes increment/decrement)
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource == null || resource.data.authorId == request.auth.uid);

      // Suggestions: Publicly readable feedback.
      match /suggestions/{suggestionId} {
        allow read: if true;
        allow create: if isSignedIn();
      }

      // Likes: Publicly readable, owner can toggle their own like.
      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // Unions: Publicly discoverable community groups.
    match /unions/{unionId} {
      allow read: if true;
      allow create, update: if isSignedIn();
    }

    // Global catch-all for consistency during development
    match /{path=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
