rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Private Chats
    match /privateChats/{chatId} {
      // Participants can read and create their own chats
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
      
      // Subcollection: messages
      match /messages/{messageId} {
        allow read, write: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants;
      }
    }
    
    // Global Posts
    match /posts/{postId} {
      // Allow authenticated users to read and write posts
      allow read, write: if request.auth != null;

      // Subcollection: likes (Fixes the reported error)
      match /likes/{userId} {
        allow read, write: if request.auth != null;
      }

      // Subcollection: suggestions (comments)
      match /suggestions/{suggestionId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Groups/Unions
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }
    match /unions/{unionId} {
      allow read, write: if request.auth != null;
    }
    
    // Users subcollections (notifications)
    match /users/{userId}/{allPaths=**} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Follows
    match /follows/{followId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}