rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Anyone can read, only owner can write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Posts: Strict Private Access (Only owner can read/list their own posts)
    match /posts/{postId} {
      // Create: Owner must set their own UID correctly
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      
      // Read/List: Only the owner can see their posts
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      
      // Update/Delete: Only owner
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }
    
    // Default fallback
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}