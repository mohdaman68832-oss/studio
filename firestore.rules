rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Private Chats: Access restricted to participants only
    // This rule is explicitly mapped to handle 'array-contains' list queries
    match /privateChats/{chatId} {
      // Allow 'list' if the authenticated user is one of the participants
      allow list: if isAuth() && (request.auth.uid in resource.data.participants);
      // Allow 'get' for specific document access
      allow get: if isAuth() && (request.auth.uid in resource.data.participants);
      // Allow creation if the creator is a participant
      allow create: if isAuth() && (request.auth.uid in request.resource.data.participants);
      // Allow updates if the user is a participant
      allow update: if isAuth() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        // Only members of the parent chat can read/write messages
        allow read, write: if isAuth() && (request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants);
      }
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }
    
    // Fallback collections for other features
    match /groups/{groupId} { allow read, write: if isAuth(); }
    match /unions/{unionId} { allow read, write: if isAuth(); }
    match /follows/{followId} { allow read, write: if isAuth(); }

    // Global Fallback (Safety Net for other authenticated paths)
    match /{path=**} {
      allow read, write: if isAuth();
    }
  }
}