
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Profiles: Publicly readable, but only owner can write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Posts: Logged in users can read and create. 
    // Filters (where uid == auth.uid) are required by the app's query logic.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      
      // Subcollections (like comments/likes)
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Ideas (Alternative collection for some modules)
    match /ideas/{ideaId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;

       match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Generic access for other collections (groups, follows, etc.)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
