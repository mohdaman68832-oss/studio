
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profiles: Publicly readable for search/browsing
    match /userProfiles/{userId} {
      allow read, list: if true;
      allow write: if isOwner(userId);
    }

    // Ideas and Posts: Publicly readable
    match /ideas/{ideaId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      
      // Allow update if owner OR if they are only changing 'likes' count
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
      );
      
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      // Suggestions (Comments) within a post
      match /suggestions/{suggestionId} {
        allow read, list: if true;
        allow create: if isSignedIn();
      }
      
      // Likes tracking subcollection
      match /likes/{userId} {
        allow read, list: if true;
        allow write: if isOwner(userId);
      }
    }

    // Notifications: Anyone can create (to send alert), only owner can read/manage
    match /users/{userId}/notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, list, update, delete: if isOwner(userId);
    }

    // Private Messages
    match /messages/{messageId} {
      allow create: if isSignedIn();
      allow read, list: if isSignedIn() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId
      );
    }
    
    // Groups
    match /groups/{groupId} {
      allow read, list: if true;
      allow write: if isSignedIn();
    }
    
    // Follow System
    match /follows/{followId} {
      allow read, list: if true;
      allow write: if isSignedIn() && (
        request.resource.data.followerId == request.auth.uid ||
        resource.data.followerId == request.auth.uid
      );
    }
  }
}
