rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Private Chats: Explicit list permission for array-contains queries
    match /privateChats/{chatId} {
      // Allows list query if participants filter matches authenticated user
      // and get requests if user is a participant
      allow read: if isAuth() && (request.auth.uid in resource.data.participants);
      
      allow create: if isAuth() && (request.auth.uid in request.resource.data.participants);
      
      allow update: if isAuth() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        allow read, write: if isAuth() && 
          exists(/databases/$(database)/documents/privateChats/$(chatId)) &&
          (request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants);
      }
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // Follows: Authenticated write
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuth() && (request.auth.uid == request.resource.data.followerId || request.auth.uid == resource.data.followerId);
    }
    
    // Global Fallback
    match /{path=**} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
  }
}