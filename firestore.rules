rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Private Chats: Explicit read/write rules for participants
    match /privateChats/{chatId} {
      // For 'list' queries (like the one in Hub), we use null-safe checks
      allow list: if isAuth() && resource.data.get('participants', []).hasAny([request.auth.uid]);
      
      // For 'get' individual document
      allow get: if isAuth() && (request.auth.uid in resource.data.get('participants', []));
      
      // Allow creation if the creator is part of the participants array
      allow create: if isAuth() && (request.auth.uid in request.resource.data.get('participants', []));
      
      // Allow updates if the user is already a participant
      allow update: if isAuth() && (request.auth.uid in resource.data.get('participants', []));

      match /messages/{messageId} {
        // Nested access control: fetch parent chat participants
        allow read, write: if isAuth() && (request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.get('participants', []));
      }
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // Follows: Authenticated check
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Global Fallback (Safety Net for other authenticated paths)
    match /{path=**} {
      allow read, write: if isAuth();
    }
  }
}