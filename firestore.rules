rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Posts: Anyone can read, only authenticated users can create.
    // Owners can update/delete their own posts.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
      
      // Nested likes and suggestions
      match /likes/{userId} {
        allow read, write: if request.auth != null;
      }
      match /suggestions/{suggestionId} {
        allow read: if true;
        allow create: if request.auth != null;
      }
    }
    
    // User profiles: Public read, Owner-only write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Follows: Authenticated read/write
    match /follows/{followId} {
      allow read, write: if request.auth != null;
    }

    // Messages: Access restricted to sender/receiver
    match /messages/{messageId} {
      allow read, write: if request.auth != null && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if request.auth != null;
    }

    // Groups: Global read, Authenticated create
    match /groups/{groupId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Global fallback for development
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
