rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Private Chats: Metadata and Messages
    match /privateChats/{chatId} {
      // Rule for listing and reading: user must be in the participants array
      // This matches query: where("participants", "array-contains", uid)
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      
      // Allow creation if the creator is one of the participants
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      
      // Allow updates (like lastMessage/timestamp) only for participants
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
      
      // Subcollection: messages
      match /messages/{messageId} {
        // Participants can read and write messages
        allow read, write: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants;
      }
    }
    
    // Global Posts
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }
    
    // Groups/Unions
    match /groups/{groupId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}