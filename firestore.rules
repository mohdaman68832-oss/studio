rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Private Chats: Access restricted to participants only
    // This rule is designed to work with the 'array-contains' query and composite index
    match /privateChats/{chatId} {
      allow get, list: if isAuth() && (request.auth.uid in resource.data.participants);
      allow create: if isAuth() && (request.auth.uid in request.resource.data.participants);
      allow update: if isAuth() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        // Participants of the parent chat can read and write messages
        allow read, write: if isAuth() && (
          request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants
        );
      }
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }
    
    // Fallback for other collections (groups, unions, follows)
    match /groups/{groupId} { allow read, write: if isAuth(); }
    match /unions/{unionId} { allow read, write: if isAuth(); }
    match /follows/{followId} { allow read, write: if isAuth(); }

    // Global Fallback for safety
    match /{path=**} {
      allow read, write: if isAuth();
    }
  }
}