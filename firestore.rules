rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Testing Mode: Authenticated users can read/write everything in posts and userProfiles
    // This removes 'list' method conflicts during development.
    match /posts/{postId} {
      allow read, write: if request.auth != null;
    }

    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default fallback
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}