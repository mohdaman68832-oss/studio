
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /userProfiles/{userId} {
      allow read: if true;
      allow create, update, delete: if isOwner(userId);
    }

    match /ideas/{ideaId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && (resource == null || resource.data.authorId == request.auth.uid);

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow create: if isSignedIn();
      }

      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    match /groups/{groupId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      
      match /members/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    match /notifications/{notifId} {
      // Allow user to list their own notifications
      allow list: if isSignedIn() && (request.query.limit <= 100);
      // Detailed check for individual documents
      allow get, update, delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }

    match /messages/{msgId} {
      // Allow listing if part of the conversation (using isSignedIn for list broad access, filtered by query)
      allow list: if isSignedIn();
      // Allow get/create if sender or receiver
      allow get, create: if isSignedIn() && (resource == null || resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || request.resource.data.senderId == request.auth.uid);
    }

    match /follows/{followId} {
      allow read, list: if true;
      allow write: if isSignedIn();
    }

    match /{path=**} {
      allow read, write: if isSignedIn();
    }
  }
}
