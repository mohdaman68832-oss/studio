rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Private Chats: Only participants can access
    match /privateChats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      
      // Explicit allow for creation (when resource doesn't exist yet)
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants;
      }
    }
    
    // Global Posts (Commonly accessed)
    match /posts/{postId} {
      allow read, write: if request.auth != null;

      match /likes/{userId} {
        allow read, write: if request.auth != null;
      }

      match /suggestions/{suggestionId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Fallback for subcollections and other paths
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }
    match /unions/{unionId} {
      allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/{allPaths=**} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
