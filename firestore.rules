rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /messages/{messageId} {
      // Allow users to list and read messages where they are a participant
      allow read, list: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        request.query.limit <= 50
      );
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /ideas/{ideaId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || resource.data.creatorId == request.auth.uid);

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow create: if isSignedIn();
      }
      
      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      
      match /chatSessions/{chatId} {
        allow read, write: if isSignedIn();
        match /messages/{msgId} {
          allow read, write: if isSignedIn();
        }
      }
    }
    
    match /groups/{groupId} {
      allow read, write: if isSignedIn();
    }
    
    match /unions/{unionId} {
      allow read, write: if isSignedIn();
    }

    match /follows/{followId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /collaborationRequests/{requestId} {
      allow read, write: if isSignedIn();
    }
  }
}