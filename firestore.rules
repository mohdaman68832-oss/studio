rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is a participant of a chat
    function isChatParticipant(chatId) {
      return request.auth != null && (
        request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants
      );
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Private Chats: Access restricted to participants only
    match /privateChats/{chatId} {
      // Allow read/list if user is in participants array. 
      // array-contains query is verified by checking request.auth.uid in resource.data.participants
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow write: if request.auth != null && request.auth.uid in request.resource.data.participants;
      
      // Explicit allow for creation
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        // Use get() to check parent chat participants for subcollection access
        allow read, write: if isChatParticipant(chatId);
      }
    }
    
    // Posts and subcollections: Authenticated read/write for development
    match /posts/{postId} {
      allow read, write: if request.auth != null;

      match /likes/{userId} {
        allow read, write: if request.auth != null;
      }

      match /suggestions/{suggestionId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Fallback and legacy paths
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }
    match /unions/{unionId} {
      allow read, write: if request.auth != null;
    }
    
    match /users/{userId}/{allPaths=**} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Global catch-all (Optional: restrictive for production)
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
