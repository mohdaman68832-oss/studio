rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }

    function isParticipant(participants) {
      return isAuth() && (request.auth.uid in participants);
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Private Chats: Must be a participant to read/write
    match /privateChats/{chatId} {
      // Allow list and get if user is in participants array
      // Explicitly checking for field existence to satisfy query verification
      allow read: if isAuth() && 
                   resource != null && 
                   ('participants' in resource.data) && 
                   (request.auth.uid in resource.data.participants);
      
      allow create: if isAuth() && (request.auth.uid in request.resource.data.participants);
      
      allow update: if isAuth() && 
                    resource != null && 
                    ('participants' in resource.data) && 
                    (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        // Nested access: verify parent chat participants
        allow read, write: if isAuth() && 
                             isParticipant(get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants);
      }
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // Follows: Authenticated write
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Global Fallback (Deny by default for non-specified paths)
    match /{path=**} {
      allow read, write: if isAuth();
    }
  }
}