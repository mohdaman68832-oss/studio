rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Universal Access for Authenticated Users (Testing Mode)
    // This resolves method: list, path: /posts errors during development.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Profiles: Publicly readable, but only owner can write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Posts specifically: Logged in users can do everything
    match /posts/{postId} {
      allow read, write: if request.auth != null;
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}