rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Private Chats: Explicit list/get permissions for participants
    match /privateChats/{chatId} {
      // Allow read (get and list) if user is a participant. 
      // Using .get() for null-safety during index building.
      allow read: if isAuth() && (request.auth.uid in resource.data.get('participants', []));
      
      // Allow creation if the current user is one of the participants
      allow create: if isAuth() && (request.auth.uid in request.resource.data.participants);
      
      // Allow updates (like lastMessage/timestamp) if user is a member
      allow update: if isAuth() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        // Tie permissions to parent chat participants
        allow read, write: if isAuth() && 
          (request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants);
      }
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // Follows: Authenticated write
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuth() && (request.auth.uid == request.resource.data.followerId || (resource != null && request.auth.uid == resource.data.followerId));
    }
    
    // Global Fallback (Secure by default)
    match /{path=**} {
      allow read, write: if isAuth();
    }
  }
}