rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is a participant
    function isAuth() {
      return request.auth != null;
    }

    // Private Chats: Access restricted to participants only
    match /privateChats/{chatId} {
      // Use 'read' to cover both 'get' and 'list' operations
      // Firestore requires this to be true for the query to be allowed
      allow read: if isAuth() && (request.auth.uid in resource.data.participants);
      
      // Allow creation if the creating user is one of the participants
      allow create: if isAuth() && (request.auth.uid in request.resource.data.participants);

      // Allow updates (like lastMessage) if user is a participant
      allow update: if isAuth() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        // Participants of the parent chat can read and write messages
        allow read, write: if isAuth() && (
          request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants
        );
      }
    }
    
    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }
    
    // Groups and Unions
    match /groups/{groupId} {
      allow read, write: if isAuth();
    }
    match /unions/{unionId} {
      allow read, write: if isAuth();
    }

    // Follows
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Fallback for other paths
    match /{path=**} {
      allow read, write: if isAuth();
    }
  }
}