rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Private Chats
    match /privateChats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && 
          request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants;
      }
    }
    
    // Global Posts (Unifying ideas and posts)
    match /posts/{postId} {
      allow read, write: if request.auth != null;

      match /likes/{userId} {
        allow read, write: if request.auth != null;
      }

      match /suggestions/{suggestionId} {
        allow read, write: if request.auth != null;
      }
    }

    // Fallback for any other path (development safety)
    match /ideas/{ideaId} {
      allow read, write: if request.auth != null;
    }
    
    // Groups/Unions
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }
    match /unions/{unionId} {
      allow read, write: if request.auth != null;
    }
    
    // Users subcollections (notifications)
    match /users/{userId}/{allPaths=**} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Follows
    match /follows/{followId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}