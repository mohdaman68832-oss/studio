
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Private Chats: Only participants can read/write metadata
    match /privateChats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      
      // Subcollection: messages
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants;
      }
    }
    
    // Groups/Posts (Existing)
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /groups/{groupId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
