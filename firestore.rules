
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * InnovateSphere Security Rules
     */

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isMember(participantIds) {
      return isSignedIn() && (request.auth.uid in participantIds);
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    match /ideas/{ideaId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.authorId);
      allow delete: if isExistingOwner(resource.data.authorId);

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow create: if isSignedIn();
      }
    }

    match /unions/{unionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /ideaRatings/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.raterId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.raterId);
      allow delete: if isExistingOwner(resource.data.raterId);
    }

    match /ideaFeedbacks/{feedbackId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.feedbackerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.feedbackerId);
      allow delete: if isExistingOwner(resource.data.feedbackerId);
    }

    match /collaborationSessions/{sessionId} {
      allow get: if isMember(resource.data.participantIds) || isOwner(resource.data.creatorId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.creatorId) || isMember(resource.data.participantIds);
      allow delete: if isExistingOwner(resource.data.creatorId);

      match /chatMessages/{messageId} {
        allow read: if isOwner(resource.data.senderId) || isMember(resource.data.participantIds);
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
