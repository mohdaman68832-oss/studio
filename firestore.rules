
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profiles Rules
    match /userProfiles/{userId} {
      allow read, list: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Ideas and Posts Rules
    match /ideas/{ideaId} {
      // Publicly readable for everyone (list and get)
      allow read, list: if true;
      allow create: if isSignedIn();
      
      // Allow update if user is creator OR if they are updating 'likes'
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
      );
      
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      // Suggestions (Comments) within a post
      match /suggestions/{suggestionId} {
        allow read, list: if true;
        allow create: if isSignedIn();
      }
      
      // Likes tracking subcollection
      match /likes/{userId} {
        allow read, list: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    // Notifications Rules
    match /users/{userId}/notifications/{notificationId} {
      allow read, list, update, delete: if isOwner(userId);
      allow create: if isSignedIn();
    }

    // Messages
    match /messages/{messageId} {
      allow read, list: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isSignedIn();
    }
    
    // Groups
    match /groups/{groupId} {
      allow read, list: if true;
      allow write: if isSignedIn();
    }
    
    // Follow System
    match /follows/{followId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
