
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * InnovateSphere Security Rules
     * Optimized for public read access and authenticated private writes.
     */

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profiles: Anyone can view (persistent themes), only owner can edit.
    match /userProfiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Ideas: Publicly readable, authenticated users can create/update.
    match /ideas/{ideaId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource == null || resource.data.authorId == request.auth.uid);

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow create: if isSignedIn();
      }

      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // Groups: Publicly discoverable community groups.
    match /groups/{groupId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      
      // Membership (Subcollection for checking if joined)
      match /members/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // Notifications: Only owner can list/read their own notifications.
    match /notifications/{notifId} {
      // Allow reading if the user is the recipient. 
      // resource == null check allows listing via query filtering.
      allow read, update, delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }

    // Follows: Publicly visible following relationships.
    match /follows/{followId} {
      allow read: if true;
      allow write: if isSignedIn() && (
        (request.resource != null && request.auth.uid == request.resource.data.followerId) || 
        (resource != null && request.auth.uid == resource.data.followerId)
      );
    }

    // Global catch-all for consistency during development
    match /{path=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
