rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Private Chats: Provably safe rules for list/get/write
    match /privateChats/{chatId} {
      // Rule for 'list' and 'get'
      allow read: if isAuth() && (request.auth.uid in resource.data.participants);
      
      // Rule for 'create' - check if current user is in participants of incoming data
      allow create: if isAuth() && (request.auth.uid in request.resource.data.participants);
      
      // Rule for 'update' - only existing participants can update (e.g., lastMessage)
      allow update: if isAuth() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        // Nested access control: fetch parent chat participants
        allow read, write: if isAuth() && (request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants);
      }
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // Follows: Authenticated check
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuth();
    }
    
    // Global Fallback (Safety Net for other authenticated paths)
    match /{path=**} {
      allow read, write: if isAuth();
    }
  }
}