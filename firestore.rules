
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profiles: Publicly readable, owner can write.
    match /userProfiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Ideas: Publicly readable, authenticated users can create.
    match /ideas/{ideaId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
      allow delete: if isSignedIn() && (resource == null || resource.data.authorId == request.auth.uid);

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow create: if isSignedIn();
      }

      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // Groups: Publicly discoverable community groups.
    match /groups/{groupId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      
      match /members/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // Notifications: Allow users to list their own notifications.
    match /notifications/{notifId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Messages: Allow users to list and read their own messages.
    match /messages/{msgId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // Follows: Publicly readable for mutual checks.
    match /follows/{followId} {
      allow read, list: if true;
      allow write: if isSignedIn();
    }

    // Global catch-all
    match /{path=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
