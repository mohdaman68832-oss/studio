rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }

    // User Profiles: Public read, Owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Private Chats: Required for Hub page query (array-contains)
    match /privateChats/{chatId} {
      // Get/List require membership
      allow get: if isAuth() && (request.auth.uid in resource.data.participants);
      allow list: if isAuth() && (request.auth.uid in resource.data.participants);
      
      // Creation requires the creator to be a participant
      allow create: if isAuth() && (request.auth.uid in request.resource.data.participants);
      
      // Updates require membership
      allow update: if isAuth() && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        allow read, write: if isAuth() && 
          exists(/databases/$(database)/documents/privateChats/$(chatId)) &&
          (request.auth.uid in get(/databases/$(database)/documents/privateChats/$(chatId)).data.participants);
      }
    }
    
    // Posts: Public read, Authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuth();

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }

      match /suggestions/{suggestionId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // Follows: Authenticated write
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuth() && (request.auth.uid == request.resource.data.followerId || (resource != null && request.auth.uid == resource.data.followerId));
    }
    
    // Global Fallback (Requires auth for safety)
    match /{path=**} {
      allow read, write: if isAuth();
    }
  }
}