
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "profilePictureUrl": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "bio": { "type": "string" },
        "stickers": { "type": "array" },
        "customColors": { "type": "object" },
        "createdAt": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "lastActive": { "type": "string" }
      },
      "required": ["id", "username", "email"]
    },
    "PrivateChat": {
      "title": "PrivateChat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["chatId", "participants"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["senderId", "text", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores user profiles with customization."
    },
    "/privateChats/{chatId}": {
      "schema": { "$ref": "#/backend/entities/PrivateChat" },
      "description": "Stores metadata for private one-to-one chats."
    },
    "/privateChats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/backend/entities/ChatMessage" },
      "description": "Stores individual messages within a private chat."
    }
  }
}
