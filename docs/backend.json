{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "profilePictureUrl": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "bio": { "type": "string" },
        "stickers": { "type": "array" },
        "customColors": { "type": "object" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "username", "email"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "content": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "innovationScore": { "type": "number" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "uid", "content", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores user profiles with customization."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/backend/entities/Post" },
      "description": "Stores user posts and innovations."
    }
  }
}